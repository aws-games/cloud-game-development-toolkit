# Create AD users using null_resource with proper lifecycle management
resource "null_resource" "create_ad_users" {
  for_each = local.users_joining_ad

  # Only run when these values change
  triggers = {
    username         = lower(each.key)
    given_name       = lookup(each.value.tags, "given_name", each.key)
    family_name      = lookup(each.value.tags, "family_name", "User")
    email            = lookup(each.value.tags, "email", "${lower(each.key)}@${var.directory_name}")
    directory_id     = var.directory_id
    directory_name   = var.directory_name
    temp_password    = var.shared_temp_password
    user_config_hash = md5(jsonencode(each.value))
  }

  # Create user on resource creation/update
  provisioner "local-exec" {
    command = <<-EOT
      #!/bin/bash
      set -e
      
      USERNAME="${lower(each.key)}"
      GIVEN_NAME="${lookup(each.value.tags, "given_name", each.key)}"
      SURNAME="${lookup(each.value.tags, "family_name", "User")}"
      EMAIL="${lookup(each.value.tags, "email", "${lower(each.key)}@${var.directory_name}")}"
      DIRECTORY_ID="${var.directory_id}"
      DOMAIN_NAME="${var.directory_name}"
      
      # Check if directory_id is provided and valid
      if [ -z "$DIRECTORY_ID" ] || [ "$DIRECTORY_ID" = "null" ] || [ "$DIRECTORY_ID" = "placeholder" ]; then
        echo "⚠ Warning: Directory ID not available yet (got: '$DIRECTORY_ID'), skipping AD user creation for $USERNAME"
        echo "This is expected on first apply. Run 'terraform apply' again after directory creation."
        exit 0
      fi
      
      echo "=== Processing AD User: $USERNAME ==="
      
      # Check if user exists using ds-data
      if aws ds-data describe-user --directory-id "$DIRECTORY_ID" --sam-account-name "$USERNAME" --query 'UserName' --output text 2>/dev/null | grep -q "^$USERNAME$"; then
        echo "User $USERNAME already exists, updating password..."
        aws ds reset-user-password --directory-id "$DIRECTORY_ID" --user-name "$USERNAME" --new-password "${var.shared_temp_password}"
        echo "✓ Password updated for user: $USERNAME"
      else
      echo "Creating new user: $USERNAME"
        
        # Create user with basic attributes (UserPrincipalName is auto-generated by AD)
        aws ds-data create-user \
          --directory-id "$DIRECTORY_ID" \
          --sam-account-name "$USERNAME" \
          --given-name "$GIVEN_NAME" \
          --surname "$SURNAME" \
          --email-address "$EMAIL" \
          --other-attributes '{"DisplayName":{"S":"'"$GIVEN_NAME $SURNAME"'"}}'
        
        # Set password for the new user
        aws ds reset-user-password --directory-id "$DIRECTORY_ID" --user-name "$USERNAME" --new-password "${var.shared_temp_password}"
        echo "✓ Created new user: $USERNAME"
      fi
      
      # Add to Remote Desktop Users group (required for DCV access)
      echo "Adding $USERNAME to Remote Desktop Users group..."
      if aws ds-data add-group-member \
        --directory-id "$DIRECTORY_ID" \
        --group-name "Remote Desktop Users" \
        --member-name "$USERNAME" \
        --member-realm "$DOMAIN_NAME" 2>/dev/null; then
        echo "✓ Added $USERNAME to Remote Desktop Users group"
      else
        echo "⚠ Note: $USERNAME may already be in Remote Desktop Users group"
      fi
    EOT
  }

  # Clean up user on resource destruction
  provisioner "local-exec" {
    when    = destroy
    command = <<-EOT
      #!/bin/bash
      
      USERNAME="${self.triggers.username}"
      DIRECTORY_ID="${self.triggers.directory_id}"
      
      echo "=== Cleaning up AD User: $USERNAME ==="
      
      # Check if directory_id is provided and valid
      if [ -z "$DIRECTORY_ID" ] || [ "$DIRECTORY_ID" = "null" ] || [ "$DIRECTORY_ID" = "placeholder" ]; then
        echo "⚠ Warning: Directory ID not available (got: '$DIRECTORY_ID'), skipping AD user cleanup for $USERNAME"
        exit 0
      fi
      
      # Check if user exists before attempting deletion
      if aws ds-data describe-user --directory-id "$DIRECTORY_ID" --sam-account-name "$USERNAME" --query 'UserName' --output text 2>/dev/null | grep -q "^$USERNAME$"; then
        echo "Deleting user: $USERNAME"
        if aws ds-data delete-user --directory-id "$DIRECTORY_ID" --sam-account-name "$USERNAME" 2>/dev/null; then
          echo "✓ Successfully deleted user: $USERNAME"
        else
          echo "⚠ Warning: Could not delete user $USERNAME (may have been deleted manually)"
        fi
      else
        echo "⚠ User $USERNAME not found (may have been deleted manually)"
      fi
    EOT
  }

  depends_on = [
    time_sleep.wait_for_instance_ready
  ]
}

# Wait for instance to be ready before domain join
resource "time_sleep" "wait_for_instance_ready" {
  depends_on      = [aws_instance.vdi_instances]
  create_duration = "60s" # Just enough time for instance to be ready
}

# Generate key pairs for users who need them

resource "tls_private_key" "vdi_keys" {
  for_each = {
    for user, config in local.processed_vdi_config : user => config
    if config.key_pair_name == null && config.create_key_pair
  }

  algorithm = "RSA"
  rsa_bits  = 4096
}

resource "aws_key_pair" "vdi_key_pairs" {
  for_each = {
    for user, config in local.processed_vdi_config : user => config
    if config.key_pair_name == null && config.create_key_pair
  }

  key_name   = "${var.project_prefix}-${each.key}-vdi-key"
  public_key = tls_private_key.vdi_keys[each.key].public_key_openssh

  tags = each.value.tags
}

# Store secrets in AWS Secrets Manager if enabled
resource "aws_secretsmanager_secret" "vdi_secrets" {
  for_each = {
    for user, config in local.processed_vdi_config : user => config
    if config.store_passwords_in_secrets_manager
  }

  name                    = "${var.project_prefix}-${each.key}-vdi-secrets-${random_id.secret_suffix[each.key].hex}"
  recovery_window_in_days = 7 # Force immediate deletion for development
  tags                    = each.value.tags
}

# Random suffix to avoid naming conflicts
resource "random_id" "secret_suffix" {
  for_each = {
    for user, config in local.processed_vdi_config : user => config
    if config.store_passwords_in_secrets_manager
  }

  byte_length = 4
}

resource "aws_secretsmanager_secret_version" "vdi_secrets" {
  for_each = {
    for user, config in local.processed_vdi_config : user => config
    if config.store_passwords_in_secrets_manager
  }

  secret_id = aws_secretsmanager_secret.vdi_secrets[each.key].id

  secret_string = jsonencode({
    user                   = each.key
    private_key            = each.value.key_pair_name == null && each.value.create_key_pair ? tls_private_key.vdi_keys[each.key].private_key_pem : null
    windows_admin_password = each.value.admin_password
    # domain_join_enabled    = each.value.join_ad
    password_type          = each.value.join_ad ? "Shared temporary password - MUST CHANGE ON FIRST LOGIN" : "Local admin only"
    ad_username            = each.value.join_ad ? "${var.directory_name}\\${lower(each.key)}" : null
    # login_instructions     = each.value.join_ad ? "Login with AD username and temporary password, then change password immediately" : "Login with Administrator account"
    # instance_type          = each.value.instance_type
    # volumes                = each.value.volumes
  })
}

# Launch templates for each VDI instance
resource "aws_launch_template" "vdi_launch_templates" {
  for_each = local.processed_vdi_config

  name_prefix   = "${var.project_prefix}-${each.key}-vdi-"
  image_id      = each.value.ami
  instance_type = each.value.instance_type
  key_name      = each.value.key_pair_name != null ? each.value.key_pair_name : (each.value.create_key_pair ? aws_key_pair.vdi_key_pairs[each.key].key_name : null)

  # Security groups - use existing or create default
  network_interfaces {
    subnet_id                   = each.value.subnet_id
    associate_public_ip_address = each.value.associate_public_ip_address
    security_groups = each.value.create_default_security_groups ? [
      aws_security_group.vdi_default_sg[each.key].id
    ] : each.value.existing_security_groups
  }

  iam_instance_profile {
    name = each.value.iam_instance_profile != null ? each.value.iam_instance_profile : aws_iam_instance_profile.vdi_instance_profile.name
  }

  # Root volume
  block_device_mappings {
    device_name = "/dev/sda1"
    ebs {
      volume_size           = each.value.volumes.Root.capacity
      volume_type           = each.value.volumes.Root.type
      iops                  = each.value.volumes.Root.type == "gp3" ? each.value.volumes.Root.iops : null
      throughput            = each.value.volumes.Root.type == "gp3" ? each.value.volumes.Root.throughput : null
      delete_on_termination = true
      encrypted             = var.ebs_encryption_enabled
      kms_key_id            = var.ebs_kms_key_id
    }
  }

  # Additional volumes
  dynamic "block_device_mappings" {
    for_each = {
      for vol_name, vol_config in each.value.volumes : vol_name => vol_config
      if vol_name != "Root"
    }
    content {
      device_name = "/dev/xvd${substr("fghijklmnopqrstuvwxyz", index(keys(each.value.volumes), block_device_mappings.key) - 1, 1)}"
      ebs {
        volume_size           = block_device_mappings.value.capacity
        volume_type           = block_device_mappings.value.type
        iops                  = block_device_mappings.value.type == "gp3" ? block_device_mappings.value.iops : null
        throughput            = block_device_mappings.value.type == "gp3" ? block_device_mappings.value.throughput : null
        delete_on_termination = true
        encrypted             = var.ebs_encryption_enabled
        kms_key_id            = var.ebs_kms_key_id
      }
    }
  }

  # Set local admin password when provided (useful for emergency access even on AD-joined instances)
  # This will should be resolved at the AMI level
  # user_data = each.value.admin_password != null ? base64encode(<<-EOT
  #   <powershell>
  #   # Simple admin password setting - AMI handles RSAT and DCV setup
  #   Write-Host "Setting local administrator password..."

  #   try {
  #       net user Administrator "${each.value.admin_password}"
  #       Write-Host "✓ Administrator password set successfully"
  #   } catch {
  #       Write-Host "✗ Failed to set administrator password: $_"
  #   }
  #   </powershell>
  # EOT
  # ) : null

  tag_specifications {
    resource_type = "instance"
    tags          = each.value.tags
  }

  tag_specifications {
    resource_type = "volume"
    tags = merge(each.value.tags, {
      Name = "${var.project_prefix}-${each.key}-vdi-volume"
    })
  }

  tags = each.value.tags
}

# EC2 instances for VDI
resource "aws_instance" "vdi_instances" {
  for_each = local.processed_vdi_config

  launch_template {
    id      = aws_launch_template.vdi_launch_templates[each.key].id
    version = "$Latest"
  }

  availability_zone = each.value.availability_zone

  tags = each.value.tags

  lifecycle {
    create_before_destroy = true
  }
}
